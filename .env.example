# Wind Turbine Analytics - Environment Configuration

# Storage Volume Path
# Local development: use default "tmp"
# Production (Databricks/cloud): set to volume path
VOLUME_PATH=tmp

# API Configuration (optional overrides)
# API_TITLE="Wind Turbine Analytics API"
# API_VERSION="1.0.0"

# CORS (optional, defaults are set in config.py)
# Add custom origins if needed, comma-separated
# CORS_ORIGINS=http://localhost:5173,https://custom-domain.com

# Authentication (disabled by default)
# ENABLE_AUTH=false

# Server (optional)
# HOST=0.0.0.0
# PORT=8000
